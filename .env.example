# Site URL (used by metadata + OG image)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js (NextAuth v5) — required for GitHub OAuth
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
#   Authorization callback URL: ${NEXT_PUBLIC_SITE_URL}/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Neon Postgres
DATABASE_URL=

# Dev-only: skip solved.ac API calls (Cloudflare blocks node fetch).
# Set to 1 to return synthetic user data; verify flow won't work.
SOLVEDAC_DEV_MOCK=

# Hidden testcase 입력 obfuscation용 AES-256-GCM 키 (32바이트 hex / 64글자).
# NEXT_PUBLIC_*이라 클라이언트 번들에 인라인됨 — 진짜 비밀 아님, network 탭으로
# 보이지 않게 하는 수준. 생성:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_JUDGE_INPUT_KEY=

# Cloudflare R2 — scripts/upload-problem-images.ts 와
# scripts/upload-clang-assets.ts 에서 사용. 런타임에는 필요 없음.
# Cloudflare 대시보드 → R2 → 버킷 Settings 의 Public URL,
# Manage API Tokens 에서 Object R/W 권한 토큰 발급.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
