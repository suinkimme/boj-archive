<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<svg xml:space="preserve" width="1293px" height="2048px" version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2971 4706" preserveAspectRatio="none">

<defs>
<!--
Based on Scenario #2 in http://datagenetics.com/blog/may32016/
except that all small ends are exactly 490/5=98 units
and the big ends differ in size (deviation of 7/168 units, ≈4%).
-->
<g id="keys" style="stroke-width:2px">
<!-- White keys  -->
<g style="fill:white;stroke:gray">
<rect x="0" y="0" width="161" height="768" />
<rect x="161" y="0" width="168" height="768" />
<rect x="329" y="0" width="161" height="768" />
<rect x="490" y="0" width="175" height="768" />
<rect x="665" y="0" width="168" height="768" />
<rect x="833" y="0" width="168" height="768" />
<rect x="1001" y="0" width="175" height="768" />
</g>

<!-- Black keys (overlap with the white keys) -->
<g style="fill:black;stroke:gray">
<rect x="98" y="0" width="98" height="512" />
<rect x="294" y="0" width="98" height="512" />
<rect x="588" y="0" width="98" height="512" />
<rect x="784" y="0" width="98" height="512" />
<rect x="980" y="0" width="98" height="512" />
</g>
</g>
</defs>

<use href="#keys" transform="translate(769,1177) scale(-1,1) rotate(270)" />
<use href="#keys" transform="translate(769,2353) scale(-1,1) rotate(270)" />
<use href="#keys" transform="translate(769,3529) scale(-1,1) rotate(270)" />
<use href="#keys" transform="translate(769,4705) scale(-1,1) rotate(270)" />

<rect x="770" y="2353" width="2200" height="1176" style="fill:green;opacity:0.3" />

<g style="stroke:gray;stroke-width:2px">
<line x1="770" x2="2970" y1="1" y2="1" />
<line x1="770" x2="2970" y1="687" y2="687" />
<line x1="770" x2="2970" y1="1177" y2="1177" />
<line x1="770" x2="2970" y1="1863" y2="1863" />
<line x1="770" x2="2970" y1="2353" y2="2353" />
<line x1="770" x2="2970" y1="3039" y2="3039" />
<line x1="770" x2="2970" y1="3529" y2="3529" />
<line x1="770" x2="2970" y1="4215" y2="4215" />
<line x1="770" x2="2970" y1="4705" y2="4705" />

<line x1="1370" x2="1370" y1="0" y2="4706" />
<line x1="1970" x2="1970" y1="0" y2="4706" />
<line x1="2570" x2="2570" y1="0" y2="4706" />
<line x1="2970" x2="2970" y1="0" y2="4706" />
</g>

<g dominant-baseline="middle" text-anchor="middle" style="font-family:sans-serif;font-size:96px" transform="translate(100,0)">
<text y="97">47</text>
<text y="1104">36</text>
<text y="2280">24</text>
<text y="3456">12</text>
<text y="4632">0</text>
</g>

<g style="fill:blue;stroke:none;">
<rect x="770" y="3138" width="200" height="96" /><!-- 15 -->
<rect x="970" y="2746" width="200" height="96" /><!-- 19 -->
<rect x="1170" y="2844" width="200" height="96" /><!-- 18 -->

<g style="opacity:0.3">
<rect x="1370" y="688" width="200" height="96" /><!-- 40 -->
<rect x="1570" y="492" width="200" height="96" /><!-- 42 -->
<rect x="1770" y="296" width="200" height="96" /><!-- 44 -->

<rect x="1970" y="2060" width="200" height="96" /><!-- 26 -->
<rect x="2170" y="1766" width="200" height="96" /><!-- 29 -->
<rect x="2370" y="1864" width="200" height="96" /><!-- 28 -->

<rect x="2570" y="4216" width="200" height="96" /><!-- 4 -->
<rect x="2770" y="4412" width="200" height="96" /><!-- 2 -->
</g>

<g style="fill:red">
<rect x="1370" y="3040" width="200" height="96" /><!-- 16 -->
<rect x="1570" y="2844" width="200" height="96" /><!-- 18 -->
<rect x="1770" y="2648" width="200" height="96" /><!-- 20 -->

<rect x="1970" y="3236" width="200" height="96" /><!-- 14 -->
<rect x="2170" y="2942" width="200" height="96" /><!-- 17 -->
<rect x="2370" y="3040" width="200" height="96" /><!-- 16 -->

<rect x="2570" y="3040" width="200" height="96" /><!-- 16 -->
