  "hint": "<div class=\"unseen\"> </div>\n<div class=\"headline\">\n<h2>✍️</h2>\n</div>\n<p>🔢➡️✅📖➗⚖️📖✖️👨‍🏫👩‍🏫👨‍🏫</p>\n<style type=\"text/css\">#description .headline:first-child {\n  display: none;\n}\n#input .headline:first-child {\n  display: none;\n}\n#output .headline:first-child {\n  display: none;\n}\n#hint .headline:first-child {\n  display: none;\n}\ndiv.unseen {\n  display: none;\n}\n</style>\n<script>\nfunction num_to_emoji(n){\n  return n.replace(/([0-9])(?!\\ufe0f|\\u20e3)/g, '$1\\ufe0f\\u20e3').replaceAll('.', '⏺️').replaceAll('%', '➗💯')\n}\n\nfunction load(){\n  Array.prototype.forEach.call(document.getElementById('problem-info').getElementsByTagName('th'), function(elem, i) {\n    elem.innerHTML=['⏰','🧠','⚖️','✅','✅👤','✅➗⚖️'][i];\n  });\n  Array.prototype.forEach.call(document.getElementById('problem-info').getElementsByTagName('td'), function(elem, i) {\n    elem.innerHTML = num_to_emoji(elem.innerHTML.replace(' 초', '⚡').replace(' MB', 'Ⓜ️🅱️'));\n  });\n  ['sampleinput1', 'sampleoutput1'].forEach(function(id) {\n    var c = document.getElementById(id).getElementsByTagName('h2')[0];\n    c.innerHTML = c.innerHTML.replace('예제 입력 1', '🏫📖1️⃣').replace('예제 출력 1', '🏫🖨️1️⃣').replace('복사', '📄');\n  });\n  var c = document.getElementsByClassName('problem-menu')[0];\n  if (c === undefined) {\n    c = document.getElementsByClassName('nav')[1];\n  }\n  Array.prototype.forEach.call(c.getElementsByTagName('li'), function(elem) {\n    var pid = elem.parentNode.getAttribute('id');\n    if (pid === 'menu2' || pid === 'menu-status') {\n      return;\n    }\n    if (Array.prototype.find.call(elem.classList, function(x) { return x === 'dropdown'; }) !== undefined) {\n      elem = elem.querySelector('a');\n    }\n    elem.innerHTML = elem.innerHTML.replace('문제 채점 현황', '🔡⚖️')\n      .replace('전체 채점 현황', '🌎⚖️')\n      .replace('내 제출', '🤔⚖️').replace('제출', '⚖️')\n      .replace('맞힌 사람', '✅👤').replace('재채점 결과', '♻️⚖️🔚')\n      .replace('채점 현황', '⚖️🔚').replace('질문 검색', '❓🔍')\n      .replace('숏코딩', '💻⛳').replace('강의 요청하기', '🏫🙏').replace('강의', '🏫')\n      .replace('문제', '🔡').replace('메인', '🌎')\n      .replace('공지사항', '📢').replace('질문', '❓').replace('스코어보드', '🆚')\n      .replace('난이도 기여', '⏳')\n      .replace('타이머', '🗳️')\n      .replace(/(\\d+)[번점]/g, function(_, m) { return num_to_emoji(m); })\n      .replace('프린트', '🖨️').replace('번', '');\n  });\n  c = document.getElementById('problem_title').parentNode;\n  c.innerHTML = c.innerHTML.replace(/(\\d+)번/g, function(_, m) { return num_to_emoji(m); })\n    .replace(/번/g, '').replace('점수', '🔢')\n    .replace('부분 성공', '🌗').replace('성공', '✅').replace('실패', '❌')\n    .replace(/(\\d+)점/g, function(_, m) { return num_to_emoji(m); });\n  c = c.querySelector('.printable');\n  if (c !== null) {\n    c.innerText = c.innerText.replace(/\\s*-\\s*/g, '➖');\n  }\n  window.onload = function() {\n    ['problem-judge-info', 'source', 'problem_tags'].forEach(function (id) {\n      var elem = document.getElementById(id);\n      if (elem === null) {\n        return;\n      }\n      elem.innerHTML = elem.innerHTML.replace(/채점 및 기타 정보/g, '⚖️ℹ️').replace(/출처/g, '✏️ℹ️').replace(/알고리즘 분류/g, '🤖📚')\n        .replace(/222222점 이상을 획득해야(.|\\n)*를 받는다./g, '2️⃣2️⃣2️⃣2️⃣2️⃣2️⃣⬆️➡️✅')\n        .replace(/문제를 만든 사람:(\\s|&nbsp;)*/g, '❓✏️👤➡️')\n        .replace(/스페셜 저지를 만든 사람:(\\s|&nbsp;)*/g, '🎉⚖️✏️👤➡️')\n        .replace(/Contest/g, '🆚')\n        .replace(/진짜 최종 구데기컵 2 2/g, '🆗🔚🐛🏆2️⃣2️⃣')\n        .replace(/구데기컵/g, '🐛🏆')\n        .replace(/구현/g, '🧑‍💻')\n        .replace(/다이나믹 프로그래밍/g, '🏃🤔')\n        .replace(/문자열/g, '🧵')\n        .replace(/jh05013(?![/\"])/g, '⤴️🏨0️⃣5️⃣0️⃣1️⃣3️⃣')\n        .replace(/kipa00(?![/\"])/g, '💂‍♀️0️⃣0️⃣')\n        .replace(/보기/g, '👀')\n        .replace(/메모 작성하기/g, '📔✏️')\n        .replace(/번/g, '')\n        .replace(/utf-8 입력 처리/g, '🌎👨‍💻📄🎱📖🧪');\n    });\n  }\n};\nload();\n</script>",
